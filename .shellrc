# Shared interactive shell configuration for bash and zsh.

case $- in
  *i*) ;;
  *) return 0 2>/dev/null || exit 0 ;;
esac

path_prepend() {
  case ":$PATH:" in
    *":$1:"*) ;;
    *) PATH="$1:$PATH" ;;
  esac
}

path_prepend "$HOME/.local/bin"
path_prepend "$HOME/bin"
path_prepend "$HOME/.cargo/bin"
export PATH

alias clippy="cargo clippy --all-features -- -D warnings -W clippy::pedantic -W clippy::nursery -W rust-2018-idioms"

if command -v exa >/dev/null 2>&1; then
  alias ll="exa -alh --git --color=always"
elif command -v eza >/dev/null 2>&1; then
  alias ll="eza -alh --git --color=always"
else
  alias ll="ls -alh"
fi

last_repository=
check_directory_for_new_repository() {
  current_repository=$(git rev-parse --show-toplevel 2>/dev/null || true)

  if [ -n "$current_repository" ] && [ "$current_repository" != "$last_repository" ] && command -v onefetch >/dev/null 2>&1; then
    onefetch
  fi

  last_repository=$current_repository
}

if [ -n "${ZSH_VERSION:-}" ]; then
  autoload -Uz add-zsh-hook
  add-zsh-hook chpwd check_directory_for_new_repository
else
  cd() {
    builtin cd "$@" || return
    check_directory_for_new_repository
  }
fi

check_directory_for_new_repository

if [ -r "$HOME/.cargo/env" ]; then
  # shellcheck disable=SC1090
  . "$HOME/.cargo/env"
fi

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate "${SHELL##*/}")"
elif [ -x "$HOME/.local/bin/mise" ]; then
  eval "$("$HOME/.local/bin/mise" activate "${SHELL##*/}")"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init "${SHELL##*/}")"
fi

if command -v zellij >/dev/null 2>&1 && [ -z "${ZELLIJ:-}" ] && [ "${TERM_PROGRAM:-}" != "vscode" ]; then
  if [ "${ZELLIJ_AUTO_ATTACH:-false}" = "true" ]; then
    zellij attach -c
  else
    zellij
  fi

  if [ "${ZELLIJ_AUTO_EXIT:-false}" = "true" ]; then
    exit
  fi
fi
